    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false
      }
    ],
    "single_file_review": false,
    "model_parameters": []
  },
  "buffer_font_size": 11.0,
  "ssh_connections": [
    {
      "host": "thinkcentre-1",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/pedroapfilho"
          ]
        }
      ]
    },
    {
      "host": "itx-1",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/pedroapfilho/ACE-Step-1.5"
          ]
        }
      ]
    }
