{
  "mcpServers": {
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "karakeep": {
      "command": "npx",
      "args": [
        "@karakeep/mcp"
      ],
      "env": {
        "KARAKEEP_API_ADDR": "https://karakeep.homelab0.local",
        "KARAKEEP_API_KEY": "KARAKEEP_API_KEY"
      }
    }
  }
}
